# Gemini API Key (get free at https://aistudio.google.com/apikey)
# Without this, the app runs in demo mode with simulated results
GEMINI_API_KEY=

# Supabase (required for login/auth on large documents)
# Get these from your Supabase project: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
